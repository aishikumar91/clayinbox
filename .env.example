# Plunk (send + inbound webhook)
# Docs: POST https://next-api.useplunk.com/v1/send
PLUNK_SECRET_KEY=sk_xxxxxxxxxxxxxxxx
# Must be next-api (api.useplunk.com rejects modern keys with 401)
PLUNK_API_URL=https://next-api.useplunk.com
PLUNK_WEBHOOK_SECRET=change-me-webhook-secret

# Supabase Postgres (Transaction pooler :6543)
DATABASE_URL=postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Mailbox access
MAILBOX_PASSWORD=change-me-strong-password
SESSION_SECRET=replace-with-32-plus-character-secret!!

# Domain / branding
MAIL_DOMAIN=clay-services.icu
DEFAULT_FROM_EMAIL=info@clay-services.icu
MAILBOX_USERNAME=info@clay-services.icu
APP_NAME=Clay Inbox
APP_URL=https://clayinbox.vercel.app
