# Plunk (required for sending)
PLUNK_SECRET_KEY=sk_xxxxxxxxxxxxxxxx
PLUNK_API_URL=https://api.useplunk.com

# Shared secret Plunk workflow should send as header:
#   x-emailbox-secret: <value>
# or Authorization: Bearer <value>
PLUNK_WEBHOOK_SECRET=change-me-webhook-secret

# Mailbox access
MAILBOX_PASSWORD=change-me-strong-password
SESSION_SECRET=replace-with-32-plus-character-secret!!

# Domain / branding
MAIL_DOMAIN=clay-services.icu
DEFAULT_FROM_EMAIL=hello@clay-services.icu
APP_NAME=Emailbox
APP_URL=https://mail.clay-services.icu

# Local / Docker SQLite path (not used on Vercel)
DATABASE_PATH=./data/emailbox.db

# For Vercel + Supabase (preferred in production):
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# After switching the app to Postgres, set DATABASE_URL in the Vercel project env.
